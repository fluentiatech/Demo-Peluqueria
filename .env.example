# ==========================================================================
#  Configuración del Agente de Citas — copia este archivo a `.env` y rellénalo
# ==========================================================================

# --- Entorno ---
APP_ENV=development          # development | production
LOG_LEVEL=INFO

# --- Seguridad ---
# API key(s) de admin/agente en CLARO (dev). En producción usa mejor hashes:
# admite varias separadas por comas (rotación). >=24 caracteres.
ADMIN_API_KEY=
# Hashes SHA-256 de las API keys (recomendado en producción: la config no guarda
# la clave en claro). Genera par clave/hash con: python -m scripts.hash_key
ADMIN_API_KEY_HASHES=
# Mostrar el dashboard HTML. Vacío = solo fuera de producción. true/false para forzar.
DASHBOARD_ENABLED=
RATE_LIMIT_PER_MIN=120       # peticiones/min por IP en /ask y webhook (0 = sin límite)
RATE_LIMIT_BACKEND=memory    # memory (1 instancia) | redis (multi-instancia, usa REDIS_URL)
AVAILABILITY_MAX_DAYS=92     # ventana máxima consultable de disponibilidad
MAX_INBOUND_CHARS=2000       # longitud máxima del mensaje entrante enviado al LLM
MAX_OUTBOUND_CHARS=4000      # longitud máxima de la respuesta por WhatsApp
MAX_MESSAGES_PER_PAYLOAD=20  # mensajes procesados como máximo por webhook
MAX_BODY_BYTES=1000000       # tamaño máximo del cuerpo de una petición
ALLOWED_HOSTS=*              # hosts permitidos en producción (CSV); * = cualquiera
TRUST_PROXY=false            # true solo si hay un proxy de confianza que fija X-Forwarded-For
# Redes que acceden al admin/panel SIN API key (LAN del local o VPN). Ej.:
# TRUSTED_ADMIN_CIDRS=127.0.0.1/32,192.168.0.0/16,100.64.0.0/10
TRUSTED_ADMIN_CIDRS=
RETENTION_DAYS=90            # purga de mensajes/eventos antiguos (RGPD); ver scripts/purge_old.py

# --- Sesiones del panel y 2FA ---
# El panel cambia la API key por una cookie de sesión firmada (HttpOnly/SameSite).
SESSION_SECRET=              # firma la cookie (alta entropía). Vacío = se deriva de las claves admin
SESSION_TTL_MIN=720          # caducidad de la sesión (12 h)
COOKIE_SECURE=               # vacío = Secure solo en producción; true/false para forzar
ADMIN_TOTP_SECRET=           # opcional: secreto base32 para el 2FA del panel
LOGIN_MAX_ATTEMPTS=5         # fallos de login por IP antes de bloquear
LOGIN_LOCKOUT_MIN=15

# --- Cifrado de PII en reposo ---
# Vacío = texto claro. Con valor, cifra nombre/teléfono/notas (ver scripts/encrypt_pii.py).
PII_ENCRYPTION_KEY=          # cadena de alta entropía; rotarla exige recifrar

# --- Auditoría y detección ---
AUDIT_ENABLED=true           # registro append-only encadenado por hash (escrituras admin + 401/403/429)
SECURITY_ALERT_THRESHOLD=20  # picos de eventos de seguridad por ventana que avisan al negocio (0 = off)
SECURITY_ALERT_WINDOW_MIN=60

# --- Escalabilidad (pool de BD; ignorado en SQLite) ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Recordatorios de cita ---
REMINDER_HOURS_BEFORE=24
REMINDER_TEMPLATE=appointment_reminder   # nombre de la plantilla aprobada en Meta
REMINDER_LANG=es

# --- Fiabilidad y alertas (Fase 4) ---
SEND_MAX_RETRIES=3           # intentos de envío de WhatsApp ante error transitorio
SEND_RETRY_BACKOFF_S=0.5     # backoff base (exponencial) entre reintentos
ALERT_LOOKBACK_HOURS=24      # ventana de eventos (handoff/error) a avisar al negocio

# --- Base de datos ---
# Desarrollo local sin Postgres (arranca al instante):
DATABASE_URL=sqlite+aiosqlite:///./citas.db
# Producción (Postgres en Hetzner / docker-compose):
# DATABASE_URL=postgresql+asyncpg://citas:citas@localhost:5432/citas

# --- Redis (opcional; estado de sesión de conversación) ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI / ChatGPT (fases 1+: NLU y redacción) ---
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini      # rutinario (la mayoría de mensajes)
OPENAI_MODEL_SMART=gpt-4o          # solo para preguntas complejas
OPENAI_MODEL_NLU=                  # vacío = usa el rápido; pon aquí el más barato
CONTEXT_CACHE_TTL_S=300            # caché en memoria del contexto del negocio

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_VERIFY_TOKEN=cambia-esto-por-un-token-secreto
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
